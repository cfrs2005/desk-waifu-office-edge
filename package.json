{
  "name": "desk-waifu-office-edge",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create office-db",
    "db:migrate": "wrangler d1 execute office-db --remote --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute office-db --local --file=schema.sql",
    "r2:create": "wrangler r2 bucket create office-assets"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "wrangler": "^3.85.0"
  }
}
